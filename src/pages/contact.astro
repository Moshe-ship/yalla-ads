---
import Base from '../layouts/Base.astro';

const nextSteps = [
  { num: '١', text: 'نتواصل معك خلال ٢٤ ساعة' },
  { num: '٢', text: 'نسوي جلسة استشارة مجانية' },
  { num: '٣', text: 'نقدم لك خطة تسويق مخصصة' },
];
---

<Base
  title="تواصل معنا — يلا ادز | استشارة مجانية"
  description="تواصل مع فريق يلا ادز واحصل على استشارة تسويقية مجانية. نساعدك تكبر مشروعك."
>

  <section class="page-header">
    <div class="container">
      <p class="page-header__tag glow-text">تواصل معنا</p>
      <h1>يلا نحكي عن مشروعك</h1>
      <p class="page-header__sub">جاهزين نساعدك. أرسل لنا رسالة ونرد عليك بأسرع وقت.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <form class="contact-form glass" id="contact-form">
          <div class="form-group">
            <label for="name">الاسم</label>
            <input type="text" id="name" name="name" class="input" placeholder="اسمك الكريم" required />
          </div>
          <div class="form-group">
            <label for="email">البريد الإلكتروني</label>
            <input type="email" id="email" name="email" class="input" placeholder="email@example.com" dir="ltr" required />
          </div>
          <div class="form-group">
            <label for="phone">رقم الجوال</label>
            <input type="tel" id="phone" name="phone" class="input" placeholder="+966 5XX XXX XXXX" dir="ltr" />
          </div>
          <div class="form-group">
            <label for="service">الخدمة المطلوبة</label>
            <select id="service" name="service" class="input">
              <option value="">اختر الخدمة</option>
              <option value="google-ads">إعلانات قوقل</option>
              <option value="social-media">إدارة السوشال ميديا</option>
              <option value="seo">تحسين محركات البحث</option>
              <option value="content">صناعة المحتوى</option>
              <option value="leads">جذب العملاء</option>
              <option value="all">باقة متكاملة</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">رسالتك</label>
            <textarea id="message" name="message" class="input" placeholder="احكيلنا عن مشروعك وكيف نقدر نساعدك..." rows="5" required></textarea>
          </div>
          <button type="submit" class="btn btn--full">أرسل الرسالة</button>
        </form>

        <div class="contact-info">
          <div class="contact-card glass">
            <h3>معلومات التواصل</h3>
            <div class="contact-card__item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <a href="mailto:info@yalla-ads.com">info@yalla-ads.com</a>
            </div>
            <div class="contact-card__item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
              <a href="https://instagram.com/yallaadss" target="_blank" rel="noopener">@yallaadss</a>
            </div>
          </div>

          <div class="next-steps glass">
            <h3>شو يصير بعدين؟</h3>
            {nextSteps.map(s => (
              <div class="next-step">
                <span class="next-step__num">{s.num}</span>
                <p>{s.text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  .page-header {
    padding: 6rem 0 3rem;
    text-align: center;
  }

  .page-header__tag {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .page-header h1 { margin-bottom: 1rem; }
  .page-header__sub { font-size: 1.1rem; max-width: 500px; margin: 0 auto; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 3rem;
    align-items: start;
  }

  .contact-form {
    padding: 2.5rem;
    border-radius: var(--radius-lg);
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-group label {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .btn--full { width: 100%; }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-card, .next-steps {
    padding: 2rem;
    border-radius: var(--radius);
  }

  .contact-card h3, .next-steps h3 {
    margin-bottom: 1.25rem;
  }

  .contact-card__item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0;
    color: var(--text-secondary);
  }

  .contact-card__item svg {
    flex-shrink: 0;
    color: var(--orange);
  }

  .contact-card__item a {
    color: var(--text-secondary);
    transition: color 0.3s;
  }

  .contact-card__item a:hover { color: var(--orange); }

  .next-step {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
  }

  .next-step__num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    min-width: 36px;
    border-radius: 50%;
    background: var(--orange);
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
  }

  .next-step p {
    font-size: 0.95rem;
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .page-header { padding: 5rem 0 2rem; }
    .contact-grid { grid-template-columns: 1fr; }
    .contact-form { padding: 1.5rem; }
  }

  @media (max-width: 480px) {
    .page-header { padding: 4rem 0 1.5rem; }
    .page-header h1 { font-size: 1.5rem; }
    .contact-form { padding: 1.25rem; }
    .contact-card, .next-steps { padding: 1.25rem; }
  }
</style>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.textContent = 'تم الإرسال ✓';
    btn.style.background = '#27ae60';
    btn.disabled = true;
    setTimeout(() => {
      btn.textContent = 'أرسل الرسالة';
      btn.style.background = '';
      btn.disabled = false;
      form.reset();
    }, 3000);
  });
</script>
