---
const services = [
  { href: '/services#google-ads', label: 'إعلانات قوقل' },
  { href: '/services#social-media', label: 'إدارة السوشال ميديا' },
  { href: '/services#seo', label: 'تحسين محركات البحث' },
  { href: '/services#content', label: 'صناعة المحتوى' },
  { href: '/services#leads', label: 'جذب العملاء' },
];
const company = [
  { href: '/about', label: 'من نحن' },
  { href: '/blog', label: 'المدونة' },
  { href: '/contact', label: 'تواصل معنا' },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <img src="/logo.png" alt="يلا ادز" class="footer__logo" />
        <p class="footer__tagline">منوصلك للزبون الصحيح</p>
        <div class="footer__social">
          <a href="https://instagram.com/yallaadss" target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/></svg>
          </a>
        </div>
      </div>
      <div class="footer__col">
        <h4>خدماتنا</h4>
        {services.map(s => <a href={s.href}>{s.label}</a>)}
      </div>
      <div class="footer__col">
        <h4>الشركة</h4>
        {company.map(c => <a href={c.href}>{c.label}</a>)}
      </div>
      <div class="footer__col">
        <h4>تواصل معنا</h4>
        <a href="mailto:info@yalla-ads.com">info@yalla-ads.com</a>
      </div>
    </div>

    <div class="footer__certs">
      <span>Google Partner</span>
      <span>Meta Certified</span>
      <span>LinkedIn Certified</span>
      <span>Semrush</span>
    </div>

    <div class="footer__bottom">
      <p>&copy; {new Date().getFullYear()} يلا ادز — Yalla Ads. جميع الحقوق محفوظة.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #0a0e1a;
    color: rgba(255,255,255,0.6);
    padding: 3rem 0 1.5rem;
  }
  .footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 2.5rem;
  }
  .footer__logo {
    height: 52px;
    width: auto;
    margin-bottom: 0.75rem;
    filter: brightness(1.3) saturate(1.2);
  }
  .footer__tagline { color: rgba(255,255,255,0.4); font-size: 0.9rem; margin-bottom: 1rem; }
  .footer__social { display: flex; gap: 0.5rem; }
  .footer__social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    color: rgba(255,255,255,0.4);
    transition: all 0.25s;
  }
  .footer__social a:hover { color: var(--orange); border-color: var(--orange); }
  .footer__col h4 {
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .footer__col a {
    display: block;
    color: rgba(255,255,255,0.4);
    font-size: 0.9rem;
    padding: 0.25rem 0;
    transition: color 0.25s;
  }
  .footer__col a:hover { color: var(--orange); }
  .footer__certs {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .footer__certs span {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.25);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .footer__bottom {
    margin-top: 1.5rem;
    text-align: center;
  }
  .footer__bottom p { font-size: 0.8rem; color: rgba(255,255,255,0.25); }
  @media (max-width: 768px) {
    .footer__grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .footer__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 480px) {
    .footer__grid { grid-template-columns: 1fr; }
    .footer__certs { gap: 1rem; }
  }
</style>
