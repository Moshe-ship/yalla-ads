---
import Base from '../layouts/Base.astro';

const services = [
  {
    id: 'google-ads',
    icon: '📢',
    title: 'إعلانات قوقل',
    subtitle: 'Google Ads',
    desc: 'نصمم حملات إعلانية على قوقل توصل لعملائك المحتملين بالوقت الصحيح. من البحث للعرض لليوتيوب — نغطي كل القنوات.',
    features: ['إعلانات البحث (Search Ads)', 'إعلانات العرض (Display Ads)', 'إعلانات يوتيوب', 'حملات التسوق (Shopping)', 'تحسين مستمر للحملات', 'تقارير أداء أسبوعية'],
  },
  {
    id: 'social-media',
    icon: '📱',
    title: 'إدارة السوشال ميديا',
    subtitle: 'Social Media Management',
    desc: 'نأخذ عنك هم السوشال ميديا بالكامل — من التخطيط والتصميم للنشر والتفاعل مع الجمهور. نخلي حساباتك تنبض بالحياة.',
    features: ['خطة محتوى شهرية', 'تصميم بوستات احترافية', 'إدارة انستقرام، تيك توك، سناب شات', 'جدولة ونشر المحتوى', 'إدارة التعليقات والرسائل', 'تقارير أداء شهرية'],
  },
  {
    id: 'seo',
    icon: '🔍',
    title: 'تحسين محركات البحث',
    subtitle: 'SEO',
    desc: 'نخلي موقعك يطلع بالنتائج الأولى في قوقل عشان الناس تلقاك بسهولة. شغل تقني ومحتوى متوافق مع محركات البحث.',
    features: ['تحليل الكلمات المفتاحية', 'تحسين المحتوى', 'SEO تقني', 'بناء روابط خلفية', 'تحسين السرعة والأداء', 'تقارير ترتيب شهرية'],
  },
  {
    id: 'content',
    icon: '🎨',
    title: 'صناعة المحتوى',
    subtitle: 'Content Creation',
    desc: 'نصنع محتوى يحكي قصة علامتك التجارية بشكل احترافي — من التصاميم للفيديوهات للمقالات.',
    features: ['تصميم جرافيك', 'إنتاج فيديوهات قصيرة (Reels)', 'كتابة محتوى تسويقي', 'تصوير منتجات', 'تصميم هوية بصرية', 'كتابة مقالات ومدونات'],
  },
  {
    id: 'leads',
    icon: '🎯',
    title: 'جذب العملاء',
    subtitle: 'Lead Generation',
    desc: 'نبني لك نظام متكامل لجذب عملاء محتملين وتحويلهم لعملاء حقيقيين. من الإعلان للتواصل للإغلاق.',
    features: ['صفحات هبوط احترافية', 'حملات جذب العملاء', 'أتمتة التسويق', 'تتبع العملاء المحتملين', 'تحسين معدل التحويل', 'تكامل مع CRM'],
  },
];
---

<Base
  title="خدماتنا — يلا ادز | حلول تسويق رقمي متكاملة"
  description="حلول تسويق رقمي شاملة: إعلانات قوقل، إدارة السوشال ميديا، SEO، صناعة المحتوى، وجذب العملاء."
>

  <section class="page-header">
    <div class="container">
      <p class="page-header__tag glow-text">خدماتنا</p>
      <h1>حلول تسويق رقمي متكاملة</h1>
      <p class="page-header__sub">كل اللي يحتاجه مشروعك عشان يوصل للجمهور الصحيح ويكبر</p>
    </div>
  </section>

  {services.map((s, i) => (
    <section class={`section ${i % 2 === 1 ? 'section--alt' : ''}`} id={s.id}>
      <div class="container">
        <div class={`service-row ${i % 2 === 1 ? 'service-row--reverse' : ''}`}>
          <div class="service-row__text">
            <span class="service-row__icon">{s.icon}</span>
            <h2>{s.title}</h2>
            <p class="service-row__subtitle">{s.subtitle}</p>
            <p class="service-row__desc">{s.desc}</p>
            <ul class="service-row__features">
              {s.features.map(f => <li>{f}</li>)}
            </ul>
            <a href="/contact" class="btn">اطلب هالخدمة</a>
          </div>
          <div class="service-row__visual glass">
            <span class="service-row__big-icon">{s.icon}</span>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="cta-box glass">
        <h2>ما تدري من وين تبدأ؟</h2>
        <p>تواصل معنا ونساعدك نختار الخدمات اللي تناسب مشروعك وميزانيتك.</p>
        <a href="/contact" class="btn">استشارة مجانية</a>
      </div>
    </div>
  </section>

</Base>

<style>
  .page-header {
    padding: 6rem 0 3rem;
    text-align: center;
  }

  .page-header__tag {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .page-header h1 { margin-bottom: 1rem; }

  .page-header__sub {
    font-size: 1.1rem;
    max-width: 550px;
    margin: 0 auto;
  }

  .section--alt {
    background: var(--glass-bg);
  }

  .service-row {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 4rem;
    align-items: center;
  }

  .service-row--reverse {
    direction: ltr;
  }

  .service-row--reverse .service-row__text {
    direction: rtl;
    text-align: right;
  }

  .service-row__icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: 1rem;
  }

  .service-row__text h2 { margin-bottom: 0.25rem; }

  .service-row__subtitle {
    font-size: 0.85rem;
    color: var(--orange);
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .service-row__desc {
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .service-row__features {
    list-style: none;
    margin-bottom: 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .service-row__features li {
    padding: 0.4rem 0;
    padding-right: 1.5rem;
    position: relative;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .service-row__features li::before {
    content: '✓';
    position: absolute;
    right: 0;
    color: var(--orange);
    font-weight: 700;
  }

  .service-row__visual {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem;
    border-radius: var(--radius-lg);
    min-height: 280px;
  }

  .service-row__big-icon {
    font-size: 6rem;
    opacity: 0.8;
  }

  .cta-box {
    text-align: center;
    padding: 4rem 2rem;
    border-radius: var(--radius-lg);
  }

  .cta-box h2 { margin-bottom: 1rem; }
  .cta-box > p { max-width: 500px; margin: 0 auto 2rem; }

  @media (max-width: 768px) {
    .service-row {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .service-row--reverse { direction: rtl; }
    .service-row__features { grid-template-columns: 1fr; }
    .service-row__visual { min-height: 200px; }
  }

  @media (max-width: 480px) {
    .cta-box { padding: 2.5rem 1.5rem; }
  }
</style>
