---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Base
  title="المدونة — يلا ادز | نصائح واستراتيجيات تسويقية"
  description="مقالات ونصائح تسويقية تساعدك تكبر مشروعك. تعلم من خبرتنا في التسويق الرقمي."
>

  <section class="page-header">
    <div class="container">
      <p class="page-header__tag glow-text">المدونة</p>
      <h1>نصائح واستراتيجيات تسويقية</h1>
      <p class="page-header__sub">محتوى تعليمي يساعدك تفهم التسويق الرقمي وتطبقه على مشروعك</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {posts.length > 0 ? (
        <div class="blog-grid">
          {posts.map(post => (
            <a href={`/blog/${post.id}`} class="blog-card glass">
              {post.data.image && <img src={post.data.image} alt={post.data.title} class="blog-card__img" loading="lazy" />}
              <div class="blog-card__body">
                <div class="blog-card__meta">
                  <time>{post.data.date}</time>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <span class="blog-card__tag">{post.data.tags[0]}</span>
                  )}
                </div>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                <span class="blog-card__read">اقرأ المقال ←</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>المقالات قادمة قريباً! تابعنا على <a href="https://instagram.com/yallaadss" target="_blank" rel="noopener">انستقرام</a> للمزيد.</p>
        </div>
      )}
    </div>
  </section>

</Base>

<style>
  .page-header {
    padding: 6rem 0 3rem;
    text-align: center;
  }

  .page-header__tag {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .page-header h1 { margin-bottom: 1rem; }
  .page-header__sub { font-size: 1.1rem; max-width: 550px; margin: 0 auto; }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .blog-card {
    display: block;
    border-radius: var(--radius);
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .blog-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .blog-card__img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .blog-card__body { padding: 1.5rem; }

  .blog-card__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .blog-card__meta time {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .blog-card__tag {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    background: var(--orange-glow);
    color: var(--orange);
    border-radius: 4px;
    font-weight: 600;
  }

  .blog-card h2 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .blog-card p {
    font-size: 0.9rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .blog-card__read {
    font-size: 0.85rem;
    color: var(--orange);
    font-weight: 600;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 0;
  }

  .empty-state a { color: var(--orange); text-decoration: underline; }

  @media (max-width: 768px) {
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>
