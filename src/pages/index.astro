---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).slice(0, 3);

const services = [
  { icon: '📢', title: 'إعلانات قوقل', desc: 'حملات مدروسة توصل إعلانك للناس اللي فعلاً يدورون على خدماتك.' },
  { icon: '📱', title: 'إدارة السوشال ميديا', desc: 'محتوى يشد الانتباه ويخلي جمهورك يتفاعل معك كل يوم.' },
  { icon: '🔍', title: 'تحسين محركات البحث', desc: 'نخلي موقعك يطلع بالنتائج الأولى لما الزبون يدور عليك.' },
  { icon: '🎨', title: 'صناعة المحتوى', desc: 'تصاميم وفيديوهات تحكي قصة علامتك التجارية بشكل احترافي.' },
  { icon: '🎯', title: 'جذب العملاء', desc: 'استراتيجيات ذكية تجيب لك عملاء جدد بشكل مستمر.' },
];

const stats = [
  { number: '+150', label: 'عميل سعيد' },
  { number: '+500', label: 'حملة ناجحة' },
  { number: '3x', label: 'متوسط زيادة المبيعات' },
  { number: '24/7', label: 'دعم متواصل' },
];

const steps = [
  { num: '١', title: 'نحلل وضعك الحالي', desc: 'نفهم مشروعك، جمهورك، ومنافسينك عشان نبني خطة صح.' },
  { num: '٢', title: 'نبني الاستراتيجية', desc: 'نصمم خطة تسويق متكاملة تناسب أهدافك وميزانيتك.' },
  { num: '٣', title: 'ننفذ ونتابع', desc: 'نشتغل على الحملات ونتابع النتائج ونطور بشكل مستمر.' },
];
---

<Base
  title="يلا ادز — منوصلك للزبون الصحيح | وكالة تسويق رقمي"
  description="وكالة تسويق رقمي متخصصة في إعلانات قوقل، إدارة السوشال ميديا، تحسين محركات البحث وصناعة المحتوى. منوصلك للزبون الصحيح."
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__bg"></div>
    <div class="container hero__inner">
      <div class="hero__text">
        <p class="hero__label"><span class="glow-text">وكالة تسويق رقمي</span></p>
        <h1>منوصلك<br/>للزبون <span class="text-orange">الصحيح</span></h1>
        <p class="hero__sub">نساعدك تكبر مشروعك عبر حملات إعلانية ذكية ومحتوى يجذب عملاء حقيقيين. يلا نبدأ!</p>
        <div class="hero__cta">
          <a href="/contact" class="btn">ابدأ الحين</a>
          <a href="/services" class="btn btn--outline">تعرف على خدماتنا</a>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__card glass">
          <div class="hero__card-stat">
            <span class="hero__card-number">+320%</span>
            <span class="hero__card-label">زيادة في المبيعات</span>
          </div>
          <div class="hero__card-bar">
            <div class="hero__card-fill"></div>
          </div>
          <p class="hero__card-note">نتائج حقيقية لعملائنا</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats">
    <div class="container">
      <div class="stats__inner">
        {stats.map(s => (
          <div class="stat">
            <span class="stat__number">{s.number}</span>
            <span class="stat__label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section" id="services">
    <div class="container">
      <div class="section-header">
        <p class="section-header__tag glow-text">خدماتنا</p>
        <h2>كل اللي يحتاجه مشروعك للنجاح</h2>
        <p>حلول تسويق رقمي متكاملة تناسب كل أنواع المشاريع</p>
      </div>
      <div class="services-grid">
        {services.map(s => (
          <div class="service-card glass">
            <span class="service-card__icon">{s.icon}</span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
      <div class="section-cta">
        <a href="/services" class="btn btn--outline">شوف كل الخدمات</a>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section section--dark">
    <div class="container">
      <div class="section-header section-header--light">
        <p class="section-header__tag glow-text">كيف نشتغل؟</p>
        <h2>ثلاث خطوات وتبدأ تشوف النتائج</h2>
      </div>
      <div class="steps-grid">
        {steps.map(s => (
          <div class="step-card">
            <span class="step-card__num">{s.num}</span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Social Media Spotlight -->
  <section class="section" id="social-spotlight">
    <div class="container">
      <div class="spotlight">
        <div class="spotlight__text">
          <p class="section-header__tag glow-text">خدمتنا المميزة</p>
          <h2>إدارة السوشال ميديا</h2>
          <p>نأخذ عنك هم السوشال ميديا بالكامل — من التخطيط والتصميم للنشر والتفاعل. نصنع محتوى يخلي جمهورك يحبك ويثق فيك.</p>
          <ul class="spotlight__list">
            <li>خطة محتوى شهرية متكاملة</li>
            <li>تصاميم احترافية لكل منصة</li>
            <li>إدارة التعليقات والرسائل</li>
            <li>تقارير أداء شهرية</li>
          </ul>
          <a href="/contact" class="btn">أبي هالخدمة</a>
        </div>
        <div class="spotlight__visual glass">
          <div class="spotlight__mockup">
            <div class="spotlight__phone">
              <div class="spotlight__screen">
                <div class="spotlight__post">
                  <div class="spotlight__post-header">
                    <div class="spotlight__avatar"></div>
                    <span>@yallaadss</span>
                  </div>
                  <div class="spotlight__post-body"></div>
                  <div class="spotlight__post-engagement">
                    <span>❤️ 1,247</span>
                    <span>💬 89</span>
                    <span>📤 156</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog Preview -->
  {posts.length > 0 && (
    <section class="section" id="blog">
      <div class="container">
        <div class="section-header">
          <p class="section-header__tag glow-text">المدونة</p>
          <h2>آخر المقالات</h2>
          <p>نصائح واستراتيجيات تسويقية تساعدك تكبر مشروعك</p>
        </div>
        <div class="blog-grid">
          {posts.map(post => (
            <a href={`/blog/${post.id}`} class="blog-card glass">
              {post.data.image && <img src={post.data.image} alt={post.data.title} class="blog-card__img" loading="lazy" />}
              <div class="blog-card__body">
                <time class="blog-card__date">{post.data.date}</time>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </div>
            </a>
          ))}
        </div>
        <div class="section-cta">
          <a href="/blog" class="btn btn--outline">كل المقالات</a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-box glass">
        <h2>جاهز تكبر مشروعك؟</h2>
        <p>احصل على استشارة مجانية وخطة تسويق مخصصة لمشروعك. يلا نبدأ!</p>
        <div class="cta-box__actions">
          <a href="/contact" class="btn">تواصل معنا الحين</a>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  /* Hero */
  .hero {
    position: relative;
    padding: 6rem 0 4rem;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 70% 20%, rgba(230, 126, 34, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse at 30% 80%, rgba(27, 46, 110, 0.04) 0%, transparent 60%);
    z-index: -1;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 4rem;
    align-items: center;
  }

  .hero__label {
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .hero h1 {
    font-size: 3.5rem;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .text-orange { color: var(--orange); }

  .hero__sub {
    font-size: 1.15rem;
    line-height: 1.8;
    margin-bottom: 2rem;
    max-width: 500px;
  }

  .hero__cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero__visual {
    display: flex;
    justify-content: center;
  }

  .hero__card {
    padding: 2rem;
    border-radius: var(--radius-lg);
    width: 100%;
    max-width: 320px;
  }

  .hero__card-stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
  }

  .hero__card-number {
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--orange);
  }

  .hero__card-label {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .hero__card-bar {
    height: 8px;
    background: var(--border);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .hero__card-fill {
    width: 82%;
    height: 100%;
    background: linear-gradient(90deg, var(--orange), var(--orange-dark));
    border-radius: 4px;
    animation: fill-bar 2s ease-out;
  }

  @keyframes fill-bar {
    from { width: 0; }
    to { width: 82%; }
  }

  .hero__card-note {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* Stats */
  .stats { padding: 0; margin-top: -1.5rem; position: relative; z-index: 2; }

  .stats__inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    background: var(--navy-deep);
    border-radius: var(--radius-lg);
    padding: 2rem;
    box-shadow: var(--shadow-lg);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 0.75rem 0.5rem;
    text-align: center;
  }

  .stat__number {
    font-size: 1.85rem;
    font-weight: 900;
    color: var(--orange);
    white-space: nowrap;
  }

  .stat__label {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    line-height: 1.3;
  }

  /* Section headers */
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-header__tag {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .section-header h2 { margin-bottom: 0.75rem; }
  .section-header p { max-width: 550px; margin: 0 auto; }

  .section-header--light h2 { color: #fff; }
  .section-header--light p { color: rgba(255, 255, 255, 0.7); }

  .section-cta { text-align: center; margin-top: 2.5rem; }

  /* Services grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    padding: 2rem 1.5rem;
    transition: all 0.3s ease;
    cursor: default;
  }

  .service-card:hover {
    transform: translateY(-3px);
    border-color: rgba(230, 126, 34, 0.2);
  }

  .service-card__icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 1rem;
  }

  .service-card h3 { margin-bottom: 0.5rem; }

  .service-card p { font-size: 0.9rem; line-height: 1.7; }

  /* Steps */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .step-card {
    text-align: center;
    padding: 2rem;
  }

  .step-card__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--orange);
    color: #fff;
    font-size: 1.5rem;
    font-weight: 900;
    margin-bottom: 1.25rem;
  }

  .step-card h3 { color: #fff; margin-bottom: 0.75rem; }
  .step-card p { color: rgba(255, 255, 255, 0.65); font-size: 0.9rem; }

  /* Spotlight */
  .spotlight {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .spotlight__text h2 { margin-bottom: 1rem; }
  .spotlight__text > p { margin-bottom: 1.5rem; line-height: 1.8; }

  .spotlight__list {
    list-style: none;
    margin-bottom: 2rem;
  }

  .spotlight__list li {
    padding: 0.5rem 0;
    color: var(--text-secondary);
    position: relative;
    padding-right: 1.5rem;
  }

  .spotlight__list li::before {
    content: '✓';
    position: absolute;
    right: 0;
    color: var(--orange);
    font-weight: 700;
  }

  .spotlight__visual {
    padding: 2rem;
    border-radius: var(--radius-lg);
    display: flex;
    justify-content: center;
  }

  .spotlight__phone {
    width: 220px;
    background: var(--navy-deep);
    border-radius: 28px;
    padding: 12px;
    box-shadow: var(--shadow-lg);
  }

  .spotlight__screen {
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    padding: 1rem;
  }

  .spotlight__post-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .spotlight__avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--orange), var(--orange-dark));
  }

  .spotlight__post-header span {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--navy-deep);
  }

  .spotlight__post-body {
    width: 100%;
    height: 160px;
    background: linear-gradient(135deg, #1B2E6E, #243B8F);
    border-radius: 8px;
    margin-bottom: 0.75rem;
  }

  .spotlight__post-engagement {
    display: flex;
    gap: 1rem;
    font-size: 0.7rem;
    color: #666;
  }

  /* Blog grid */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
    gap: 1.5rem;
  }

  .blog-card {
    border-radius: var(--radius);
    overflow: hidden;
    transition: all 0.3s ease;
    display: block;
  }

  .blog-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .blog-card__img {
    width: 100%;
    height: 180px;
    object-fit: cover;
  }

  .blog-card__body { padding: 1.5rem; }

  .blog-card__date {
    font-size: 0.8rem;
    color: var(--orange);
    font-weight: 600;
  }

  .blog-card h3 {
    font-size: 1.05rem;
    margin: 0.5rem 0;
    line-height: 1.5;
  }

  .blog-card p {
    font-size: 0.85rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* CTA Box */
  .cta-box {
    text-align: center;
    padding: 4rem 2rem;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, var(--glass-bg), var(--glass-bg-strong));
    border: 1px solid var(--border);
  }

  .cta-box h2 { margin-bottom: 1rem; }
  .cta-box > p { max-width: 500px; margin: 0 auto 2rem; }

  /* Responsive */
  @media (max-width: 768px) {
    .hero { padding: 4rem 0 3rem; }
    .hero__inner { grid-template-columns: 1fr; gap: 2rem; }
    .hero h1 { font-size: 2.5rem; }
    .hero__visual { order: -1; }
    .hero__card { max-width: 100%; }
    .stats__inner { grid-template-columns: repeat(2, 1fr); gap: 0; }
    .steps-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .spotlight { grid-template-columns: 1fr; gap: 2rem; }
    .spotlight__phone { width: 180px; }
    .blog-grid { grid-template-columns: 1fr; }
    .services-grid { grid-template-columns: repeat(auto-fill, minmax(min(200px, 100%), 1fr)); }
  }

  @media (max-width: 480px) {
    .hero h1 { font-size: 2rem; }
    .hero__sub { font-size: 1rem; }
    .hero__cta { flex-direction: column; }
    .hero__cta .btn { width: 100%; text-align: center; }
    .stats { margin-top: -1rem; }
    .stats__inner { padding: 1rem 0.5rem; grid-template-columns: repeat(2, 1fr); }
    .stat { padding: 0.5rem 0.25rem; }
    .stat__number { font-size: 1.3rem; }
    .stat__label { font-size: 0.65rem; }
    .cta-box { padding: 2.5rem 1.5rem; }
    .spotlight__visual { padding: 1rem; }
    .spotlight__phone { width: 160px; }
  }
</style>
