---
---
<div class="tool" id="audit-tool">
  <div class="tool__step" id="tool-form">
    <h3>تقييم جاهزيتك الرقمية</h3>
    <p>أجب على هذه الأسئلة لمعرفة مستوى حضورك الرقمي واكتشاف فرص النمو</p>

    <div class="tool__questions" id="tool-questions">
      <label class="tool__q">
        <input type="checkbox" name="q" value="website" />
        <span>لديّ موقع إلكتروني يعمل بشكل جيد</span>
      </label>
      <label class="tool__q">
        <input type="checkbox" name="q" value="mobile" />
        <span>موقعي متوافق مع الهواتف الذكية</span>
      </label>
      <label class="tool__q">
        <input type="checkbox" name="q" value="google-ads" />
        <span>أدير حملات إعلانية على Google</span>
      </label>
      <label class="tool__q">
        <input type="checkbox" name="q" value="social" />
        <span>لديّ حسابات نشطة على وسائل التواصل</span>
      </label>
      <label class="tool__q">
        <input type="checkbox" name="q" value="content" />
        <span>أنشر محتوى بانتظام (أسبوعياً على الأقل)</span>
      </label>
      <label class="tool__q">
        <input type="checkbox" name="q" value="seo" />
        <span>موقعي يظهر في نتائج البحث الأولى</span>
      </label>
      <label class="tool__q">
        <input type="checkbox" name="q" value="analytics" />
        <span>أتابع أداء حملاتي عبر أدوات التحليل</span>
      </label>
      <label class="tool__q">
        <input type="checkbox" name="q" value="reviews" />
        <span>لديّ تقييمات إيجابية على Google أو وسائل التواصل</span>
      </label>
      <label class="tool__q">
        <input type="checkbox" name="q" value="email" />
        <span>أستخدم التسويق عبر البريد الإلكتروني</span>
      </label>
      <label class="tool__q">
        <input type="checkbox" name="q" value="strategy" />
        <span>لديّ استراتيجية تسويق رقمي واضحة ومكتوبة</span>
      </label>
    </div>

    <button class="btn" id="tool-calculate" style="width:100%">احصل على تقييمك</button>
  </div>

  <div class="tool__step tool__results" id="tool-results" style="display:none">
    <div class="tool__score-row">
      <div class="tool__score-circle">
        <svg viewBox="0 0 120 120" class="tool__ring">
          <circle cx="60" cy="60" r="54" stroke="var(--border)" stroke-width="8" fill="none"/>
          <circle cx="60" cy="60" r="54" stroke="#1B2E6E" stroke-width="8" fill="none"
            stroke-dasharray="339.3" stroke-dashoffset="339.3" stroke-linecap="round"
            id="tool-ring" transform="rotate(-90 60 60)"/>
        </svg>
        <span class="tool__score-num" id="tool-score-num">0</span>
      </div>
      <div class="tool__score-info">
        <span class="tool__score-label">نتيجة جاهزيتك الرقمية</span>
        <span class="tool__score-verdict" id="tool-verdict">—</span>
      </div>
    </div>

    <div class="tool__breakdown" id="tool-breakdown"></div>

    <div class="tool__cta">
      <p>هل تريد خطة تسويق مفصّلة مجاناً؟</p>
      <a href="/contact" class="btn" style="width:100%">احصل على خطتك المجانية</a>
      <button class="tool__reset" id="tool-reset">إعادة التقييم</button>
    </div>
  </div>
</div>

<style>
  .tool {
    padding: 1.75rem;
    border-radius: var(--radius-lg);
    background: var(--glass-bg-strong);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border);
  }
  .tool h3 { font-size: 1.1rem; margin-bottom: 0.25rem; }
  .tool > .tool__step > p { font-size: 0.85rem; margin-bottom: 1.25rem; }
  .tool__questions { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.25rem; }
  .tool__q {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all 0.2s;
    font-size: 0.88rem;
    color: var(--text-secondary);
  }
  .tool__q:hover { border-color: #1B2E6E; }
  :global([data-theme="dark"]) .tool__q:hover { border-color: #5b8cff; }
  .tool__q:has(input:checked) {
    border-color: #1B2E6E;
    background: rgba(27, 46, 110, 0.06);
    color: var(--text);
  }
  :global([data-theme="dark"]) .tool__q:has(input:checked) { border-color: #5b8cff; background: rgba(91, 140, 255, 0.1); }
  .tool__q input { accent-color: #1B2E6E; width: 16px; height: 16px; cursor: pointer; }
  :global([data-theme="dark"]) .tool__q input { accent-color: #5b8cff; }
  .tool__results { text-align: center; }
  .tool__score-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
    text-align: right;
  }
  .tool__score-circle { position: relative; width: 90px; height: 90px; flex-shrink: 0; }
  .tool__ring { width: 100%; height: 100%; }
  .tool__score-num {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    font-weight: 900;
    color: var(--orange);
  }
  .tool__score-info { display: flex; flex-direction: column; gap: 0.2rem; }
  .tool__score-label { font-size: 0.8rem; color: var(--text-muted); }
  .tool__score-verdict { font-size: 1rem; font-weight: 800; color: var(--text); }
  .tool__breakdown { margin-bottom: 1.25rem; text-align: right; }
  .tool__breakdown-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.82rem;
  }
  .tool__breakdown-item span:first-child { color: var(--text-secondary); }
  .tool__breakdown-item .pass { color: #2ecc71; font-weight: 700; }
  .tool__breakdown-item .fail { color: #e74c3c; font-weight: 700; }
  .tool__cta p { font-size: 0.85rem; margin-bottom: 0.75rem; color: var(--text-secondary); }
  .tool__reset {
    margin-top: 0.6rem;
    background: none;
    border: none;
    color: var(--text-muted);
    font-family: var(--font);
    font-size: 0.82rem;
    cursor: pointer;
    text-decoration: underline;
  }
</style>

<script>
  const categories: Record<string, { label: string; items: string[] }> = {
    presence: { label: 'الحضور الرقمي', items: ['website', 'mobile', 'social'] },
    marketing: { label: 'التسويق والإعلان', items: ['google-ads', 'content', 'seo'] },
    optimization: { label: 'التحسين والقياس', items: ['analytics', 'reviews', 'email', 'strategy'] },
  };

  document.getElementById('tool-calculate')?.addEventListener('click', () => {
    const checked = Array.from(document.querySelectorAll('#tool-questions input:checked')).map(
      (el) => (el as HTMLInputElement).value
    );

    const score = checked.length * 10;

    // Animate ring
    const ring = document.getElementById('tool-ring') as SVGCircleElement;
    ring.style.transition = 'stroke-dashoffset 1s ease';
    ring.style.strokeDashoffset = String(339.3 * (1 - score / 100));

    // Animate number
    const numEl = document.getElementById('tool-score-num')!;
    let c = 0;
    const interval = setInterval(() => {
      c += 2;
      if (c >= score) { c = score; clearInterval(interval); }
      numEl.textContent = c + '%';
    }, 25);

    // Verdict
    let verdict = '';
    if (score <= 20) verdict = 'بحاجة ماسّة للتطوير';
    else if (score <= 40) verdict = 'هناك فرص كبيرة للنمو';
    else if (score <= 60) verdict = 'أساس جيد يحتاج تعزيزاً';
    else if (score <= 80) verdict = 'أداء جيد مع مجال للتحسين';
    else verdict = 'مستوى متقدّم — حان وقت التوسّع';
    document.getElementById('tool-verdict')!.textContent = verdict;

    // Breakdown by category
    const bd = document.getElementById('tool-breakdown')!;
    let html = '';
    for (const [, cat] of Object.entries(categories)) {
      const catChecked = cat.items.filter(i => checked.includes(i)).length;
      const catTotal = cat.items.length;
      const pct = Math.round((catChecked / catTotal) * 100);
      html += `<div class="tool__breakdown-item"><span>${cat.label}</span><span class="${pct >= 50 ? 'pass' : 'fail'}">${pct}%</span></div>`;
    }
    bd.innerHTML = html;

    document.getElementById('tool-form')!.style.display = 'none';
    document.getElementById('tool-results')!.style.display = 'block';
  });

  document.getElementById('tool-reset')?.addEventListener('click', () => {
    document.getElementById('tool-form')!.style.display = 'block';
    document.getElementById('tool-results')!.style.display = 'none';
    document.querySelectorAll('#tool-questions input').forEach(el => (el as HTMLInputElement).checked = false);
    (document.getElementById('tool-ring') as SVGCircleElement).style.strokeDashoffset = '339.3';
  });
</script>
