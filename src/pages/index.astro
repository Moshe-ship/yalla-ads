---
import Base from '../layouts/Base.astro';
import AdBudgetTool from '../components/AdBudgetTool.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).slice(0, 3);

const services = [
  { icon: '📢', title: 'إعلانات قوقل', desc: 'حملات مدروسة توصل إعلانك للناس اللي فعلاً يدورون على خدماتك.' },
  { icon: '📱', title: 'إدارة السوشال ميديا', desc: 'محتوى يشد الانتباه ويخلي جمهورك يتفاعل معك كل يوم.' },
  { icon: '🔍', title: 'تحسين محركات البحث', desc: 'نخلي موقعك يطلع بالنتائج الأولى لما الزبون يدور عليك.' },
  { icon: '🎨', title: 'صناعة المحتوى', desc: 'تصاميم وفيديوهات تحكي قصة علامتك التجارية بشكل احترافي.' },
  { icon: '🎯', title: 'جذب العملاء', desc: 'استراتيجيات ذكية تجيب لك عملاء جدد بشكل مستمر.' },
];

const stats = [
  { number: '+150', label: 'عميل' },
  { number: '+500', label: 'حملة ناجحة' },
  { number: '3x', label: 'زيادة مبيعات' },
  { number: '24/7', label: 'دعم' },
];

const steps = [
  { num: '١', title: 'نحلل وضعك', desc: 'نفهم مشروعك وجمهورك ومنافسينك.' },
  { num: '٢', title: 'نبني الخطة', desc: 'نصمم استراتيجية تناسب أهدافك.' },
  { num: '٣', title: 'ننفذ ونطور', desc: 'نشتغل ونتابع النتائج بشكل مستمر.' },
];

const certifications = [
  { name: 'Google Partner', icon: 'G' },
  { name: 'Meta Certified', icon: 'M' },
  { name: 'LinkedIn Certified', icon: 'in' },
  { name: 'X (Twitter)', icon: 'X' },
  { name: 'Semrush', icon: 'S' },
];
---

<Base
  title="يلا ادز — منوصلك للزبون الصحيح | وكالة تسويق رقمي"
  description="وكالة تسويق رقمي متخصصة في إعلانات قوقل، إدارة السوشال ميديا، تحسين محركات البحث وصناعة المحتوى. منوصلك للزبون الصحيح."
>

  <!-- Hero -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="tag">وكالة تسويق رقمي معتمدة</span>
        <h1>منوصلك<br/>للزبون <span class="hero__orange">الصحيح</span></h1>
        <p class="hero__sub">نساعدك تكبر مشروعك عبر حملات إعلانية ذكية ومحتوى يجذب عملاء حقيقيين.</p>
        <div class="hero__cta">
          <a href="/contact" class="btn">ابدأ الحين</a>
          <a href="/services" class="btn btn--outline">خدماتنا</a>
        </div>
      </div>
      <div class="hero__tool">
        <AdBudgetTool />
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats-section section--blue">
    <div class="container">
      <div class="stats-row">
        {stats.map(s => (
          <div class="stat">
            <span class="stat__num">{s.number}</span>
            <span class="stat__label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <div class="sec-header">
        <span class="tag">خدماتنا</span>
        <h2>كل اللي يحتاجه مشروعك</h2>
      </div>
      <div class="services-grid">
        {services.map(s => (
          <a href="/services" class="svc-card">
            <span class="svc-card__icon">{s.icon}</span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section section--dark">
    <div class="container">
      <div class="sec-header sec-header--light">
        <span class="tag">كيف نشتغل؟</span>
        <h2>ثلاث خطوات وتبدأ تشوف النتائج</h2>
      </div>
      <div class="steps-grid">
        {steps.map(s => (
          <div class="step">
            <span class="step__num">{s.num}</span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="section section--light">
    <div class="container">
      <div class="sec-header">
        <span class="tag">شركاء معتمدين</span>
        <h2>نشتغل مع أكبر المنصات</h2>
      </div>
      <div class="certs-row">
        {certifications.map(c => (
          <div class="cert">
            <span class="cert__icon">{c.icon}</span>
            <span class="cert__name">{c.name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Social Media Spotlight -->
  <section class="section">
    <div class="container">
      <div class="spotlight">
        <div class="spotlight__text">
          <span class="tag">خدمتنا المميزة</span>
          <h2>إدارة السوشال ميديا</h2>
          <p>نأخذ عنك هم السوشال ميديا بالكامل — من التخطيط والتصميم للنشر والتفاعل.</p>
          <ul class="check-list">
            <li>خطة محتوى شهرية متكاملة</li>
            <li>تصاميم احترافية لكل منصة</li>
            <li>إدارة التعليقات والرسائل</li>
            <li>تقارير أداء شهرية</li>
          </ul>
          <a href="/contact" class="btn">أبي هالخدمة</a>
        </div>
        <div class="spotlight__visual">
          <div class="spotlight__phone">
            <div class="spotlight__screen">
              <div class="spotlight__post-header">
                <div class="spotlight__avatar"></div>
                <span>@yallaadss</span>
              </div>
              <div class="spotlight__post-body"></div>
              <div class="spotlight__engagement">
                <span>❤️ 1,247</span>
                <span>💬 89</span>
                <span>📤 156</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog -->
  {posts.length > 0 && (
    <section class="section section--light">
      <div class="container">
        <div class="sec-header">
          <span class="tag">المدونة</span>
          <h2>آخر المقالات</h2>
        </div>
        <div class="blog-grid">
          {posts.map(post => (
            <a href={`/blog/${post.id}`} class="blog-card">
              <div class="blog-card__body">
                <time>{post.data.date}</time>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </div>
            </a>
          ))}
        </div>
        <div class="sec-cta"><a href="/blog" class="btn btn--outline">كل المقالات</a></div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section section--blue cta-final">
    <div class="container" style="text-align:center;">
      <h2>جاهز تكبر مشروعك؟</h2>
      <p style="max-width:500px;margin:0.75rem auto 1.5rem;">احصل على استشارة مجانية وخطة تسويق مخصصة. يلا نبدأ!</p>
      <a href="/contact" class="btn btn--white">تواصل معنا الحين</a>
    </div>
  </section>

</Base>

<style>
  /* Hero */
  .hero { padding: 5rem 0 3rem; }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 3rem;
    align-items: center;
  }
  .hero__orange { color: var(--orange); }
  .hero h1 { font-size: 3.2rem; margin-bottom: 1rem; }
  .hero__sub { font-size: 1.1rem; line-height: 1.8; margin-bottom: 1.5rem; }
  .hero__cta { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  /* Stats */
  .stats-section { padding: 2rem 0; }
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }
  .stat { text-align: center; padding: 1rem 0.5rem; }
  .stat__num { display: block; font-size: 2rem; font-weight: 900; color: var(--orange); }
  .stat__label { font-size: 0.8rem; color: rgba(255,255,255,0.7); text-transform: uppercase; letter-spacing: 0.03em; }

  /* Section header */
  .sec-header { text-align: center; margin-bottom: 2.5rem; }
  .sec-header h2 { margin-bottom: 0.25rem; }
  .sec-header--light h2 { color: #fff; }
  .sec-cta { text-align: center; margin-top: 2rem; }

  /* Services */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }
  .svc-card {
    display: block;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: all 0.25s;
    background: var(--bg);
  }
  .svc-card:hover {
    border-color: var(--orange);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .svc-card__icon { font-size: 1.75rem; display: block; margin-bottom: 0.75rem; }
  .svc-card h3 { margin-bottom: 0.35rem; color: var(--blue); }
  :global([data-theme="dark"]) .svc-card h3 { color: var(--text); }
  .svc-card p { font-size: 0.85rem; line-height: 1.6; }

  /* Steps */
  .steps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .step { text-align: center; }
  .step__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--orange);
    color: #fff;
    font-size: 1.25rem;
    font-weight: 900;
    margin-bottom: 1rem;
  }
  .step h3 { color: #fff; margin-bottom: 0.5rem; }
  .step p { font-size: 0.9rem; }

  /* Certifications */
  .certs-row {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .cert {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    min-width: 100px;
  }
  .cert__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--blue);
    color: #fff;
    font-size: 1.1rem;
    font-weight: 900;
    letter-spacing: -0.02em;
  }
  .cert__name { font-size: 0.8rem; font-weight: 600; color: var(--text-secondary); text-align: center; }

  /* Spotlight */
  .spotlight {
    display: grid;
    grid-template-columns: 1fr 0.8fr;
    gap: 3rem;
    align-items: center;
  }
  .spotlight__text h2 { margin-bottom: 0.75rem; }
  .spotlight__text > p { margin-bottom: 1.25rem; line-height: 1.8; }
  .check-list { list-style: none; margin-bottom: 1.5rem; }
  .check-list li {
    padding: 0.4rem 0;
    padding-right: 1.5rem;
    position: relative;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
  .check-list li::before {
    content: '✓';
    position: absolute;
    right: 0;
    color: var(--orange);
    font-weight: 700;
  }
  .spotlight__phone {
    width: 220px;
    margin: 0 auto;
    background: var(--blue-deep);
    border-radius: 28px;
    padding: 12px;
    box-shadow: var(--shadow-lg);
  }
  .spotlight__screen {
    background: #fff;
    border-radius: 20px;
    padding: 1rem;
    overflow: hidden;
  }
  .spotlight__post-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .spotlight__avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--orange), var(--orange-dark));
  }
  .spotlight__post-header span { font-size: 0.75rem; font-weight: 700; color: #111; }
  .spotlight__post-body {
    width: 100%;
    height: 160px;
    background: linear-gradient(135deg, #1B2E6E, #2A4494);
    border-radius: 8px;
    margin-bottom: 0.75rem;
  }
  .spotlight__engagement { display: flex; gap: 0.75rem; font-size: 0.7rem; color: #666; }

  /* Blog */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
    gap: 1rem;
  }
  .blog-card {
    display: block;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: all 0.25s;
    background: var(--bg);
  }
  .blog-card:hover { border-color: var(--orange); transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .blog-card__body { padding: 1.25rem; }
  .blog-card time { font-size: 0.8rem; color: var(--orange); font-weight: 600; }
  .blog-card h3 { font-size: 1rem; margin: 0.4rem 0; line-height: 1.5; }
  .blog-card p {
    font-size: 0.85rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* CTA */
  .cta-final h2 { color: #fff; }
  .cta-final p { color: rgba(255,255,255,0.8); }

  /* Responsive */
  @media (max-width: 768px) {
    .hero__inner { grid-template-columns: 1fr; gap: 2rem; }
    .hero h1 { font-size: 2.4rem; }
    .hero__tool { order: -1; }
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .steps-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .spotlight { grid-template-columns: 1fr; gap: 2rem; }
    .spotlight__phone { width: 180px; }
    .blog-grid { grid-template-columns: 1fr; }
    .certs-row { gap: 1.25rem; }
    .cert__icon { width: 48px; height: 48px; font-size: 0.95rem; }
  }

  @media (max-width: 480px) {
    .hero { padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2rem; }
    .hero__cta { flex-direction: column; }
    .hero__cta .btn { width: 100%; text-align: center; }
    .stat__num { font-size: 1.5rem; }
    .services-grid { grid-template-columns: 1fr; }
  }
</style>
