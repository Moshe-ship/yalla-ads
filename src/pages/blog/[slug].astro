---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = (await getCollection('blog')).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const related = allPosts.filter(p => p.id !== post.id).slice(0, 3);

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.date,
  "author": {
    "@type": "Organization",
    "name": "يلا ادز"
  },
  "publisher": {
    "@type": "Organization",
    "name": "يلا ادز",
    "logo": { "@type": "ImageObject", "url": "https://yalla-ads.com/logo.png" }
  }
});
---

<Base
  title={`${post.data.title} — يلا ادز`}
  description={post.data.description}
  type="article"
  image={post.data.image}
  schema={schema}
>

  <article class="article">
    <div class="container">
      <header class="article__header">
        <a href="/blog" class="article__back">العودة للمدونة ←</a>
        <h1>{post.data.title}</h1>
        <div class="article__meta">
          <time>{post.data.date}</time>
          <span>·</span>
          <span>{post.data.author}</span>
        </div>
        {post.data.tags && (
          <div class="article__tags">
            {post.data.tags.map(tag => <span class="article__tag">{tag}</span>)}
          </div>
        )}
      </header>

      {post.data.image && (
        <img src={post.data.image} alt={post.data.title} class="article__hero" />
      )}

      <div class="article__body prose">
        <Content />
      </div>

      <div class="article__cta glass">
        <h3>تبي تكبر مشروعك؟</h3>
        <p>تواصل معنا واحصل على استشارة تسويقية مجانية.</p>
        <a href="/contact" class="btn">تواصل معنا</a>
      </div>

      {related.length > 0 && (
        <section class="related">
          <h2>مقالات ذات صلة</h2>
          <div class="related__grid">
            {related.map(r => (
              <a href={`/blog/${r.id}`} class="related__card glass">
                <h3>{r.data.title}</h3>
                <time>{r.data.date}</time>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </article>

</Base>

<style>
  .article { padding: 5rem 0 2rem; }

  .article__back {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--orange);
    margin-bottom: 2rem;
    font-weight: 600;
  }

  .article__back:hover { text-decoration: underline; }

  .article__header { margin-bottom: 2rem; }

  .article__header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    max-width: 700px;
  }

  .article__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .article__tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .article__tag {
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    background: var(--orange-glow);
    color: var(--orange);
    border-radius: 4px;
    font-weight: 600;
  }

  .article__hero {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: var(--radius);
    margin-bottom: 2.5rem;
  }

  /* Prose styling for markdown content */
  .prose {
    max-width: 700px;
    font-size: 1.05rem;
    line-height: 1.9;
  }

  .prose :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .prose :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
    color: var(--text-secondary);
  }

  .prose :global(ul), .prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-right: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
    color: var(--text-secondary);
  }

  .prose :global(strong) { color: var(--text); }

  .prose :global(a) {
    color: var(--orange);
    text-decoration: underline;
  }

  .prose :global(blockquote) {
    border-right: 3px solid var(--orange);
    padding-right: 1.5rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--text-muted);
  }

  .prose :global(code) {
    background: var(--glass-bg);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .article__cta {
    text-align: center;
    padding: 3rem 2rem;
    border-radius: var(--radius-lg);
    margin: 3rem 0;
    max-width: 700px;
  }

  .article__cta h3 { margin-bottom: 0.75rem; }
  .article__cta p { margin-bottom: 1.5rem; max-width: 400px; margin-inline: auto; }

  .related { margin-top: 3rem; }
  .related h2 { margin-bottom: 1.5rem; }

  .related__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(250px, 100%), 1fr));
    gap: 1rem;
  }

  .related__card {
    padding: 1.5rem;
    border-radius: var(--radius);
    transition: all 0.3s ease;
    display: block;
  }

  .related__card:hover {
    transform: translateY(-2px);
    border-color: rgba(230, 126, 34, 0.2);
  }

  .related__card h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .related__card time {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .article__header h1 { font-size: 1.8rem; }
    .related__grid { grid-template-columns: 1fr; }
    .article__cta { padding: 2rem 1.5rem; }
  }

  @media (max-width: 480px) {
    .article { padding: 3.5rem 0 1.5rem; }
    .article__header h1 { font-size: 1.5rem; }
    .prose { font-size: 0.95rem; }
    .article__cta { padding: 1.5rem 1rem; }
  }
</style>
