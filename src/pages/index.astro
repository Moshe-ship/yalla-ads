---
import Base from '../layouts/Base.astro';
import AdBudgetTool from '../components/AdBudgetTool.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).slice(0, 3);

const services = [
  { icon: '📢', title: 'إعلانات Google', desc: 'حملات إعلانية مدروسة تصل إلى العملاء المحتملين في اللحظة المناسبة.' },
  { icon: '📱', title: 'إدارة وسائل التواصل', desc: 'إدارة شاملة لحساباتكم مع محتوى احترافي يعزّز التفاعل والمتابعة.' },
  { icon: '🔍', title: 'تحسين محركات البحث', desc: 'نضمن ظهور موقعكم في النتائج الأولى عند بحث العملاء عن خدماتكم.' },
  { icon: '🎨', title: 'صناعة المحتوى', desc: 'تصاميم وفيديوهات احترافية تعكس هوية علامتكم التجارية بتميّز.' },
  { icon: '🎯', title: 'جذب العملاء', desc: 'أنظمة متكاملة لاستقطاب العملاء المحتملين وتحويلهم إلى عملاء فعليين.' },
];

const stats = [
  { number: '+150', label: 'عميل' },
  { number: '+500', label: 'حملة ناجحة' },
  { number: '3x', label: 'نمو المبيعات' },
  { number: '24/7', label: 'دعم متواصل' },
];

const steps = [
  { num: '1', title: 'التحليل', desc: 'دراسة مشروعكم وجمهوركم المستهدف والمنافسين.' },
  { num: '2', title: 'التخطيط', desc: 'بناء استراتيجية تسويقية متكاملة تناسب أهدافكم.' },
  { num: '3', title: 'التنفيذ', desc: 'إطلاق الحملات ومتابعة الأداء والتطوير المستمر.' },
];
---

<Base
  title="يلا ادز — منوصلك للزبون الصحيح | وكالة تسويق رقمي"
  description="وكالة تسويق رقمي متخصصة في إعلانات Google، إدارة وسائل التواصل الاجتماعي، تحسين محركات البحث وصناعة المحتوى الرقمي."
>

  <!-- Hero -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <span class="tag">وكالة تسويق رقمي معتمدة</span>
        <h1>منوصلك<br/>للزبون <span class="hero__orange">الصحيح</span></h1>
        <p class="hero__sub">نساعدكم على تنمية أعمالكم من خلال حملات إعلانية ذكية ومحتوى رقمي يستقطب العملاء المناسبين.</p>
        <div class="hero__cta">
          <a href="/contact" class="btn">ابدأ الآن</a>
          <a href="/services" class="btn btn--outline">خدماتنا</a>
        </div>
      </div>
      <div class="hero__tool">
        <AdBudgetTool />
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-row">
        {stats.map(s => (
          <div class="stat">
            <span class="stat__num">{s.number}</span>
            <span class="stat__label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <div class="sec-header">
        <span class="tag">خدماتنا</span>
        <h2>كل ما يحتاجه مشروعكم للنجاح الرقمي</h2>
      </div>
      <div class="services-grid">
        {services.map(s => (
          <a href="/services" class="svc-card">
            <span class="svc-card__icon">{s.icon}</span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section section--light">
    <div class="container">
      <div class="sec-header">
        <span class="tag">منهجية العمل</span>
        <h2>ثلاث خطوات نحو نتائج ملموسة</h2>
      </div>
      <div class="steps-grid">
        {steps.map(s => (
          <div class="step">
            <span class="step__num">{s.num}</span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="section">
    <div class="container">
      <div class="sec-header">
        <span class="tag">شركاء معتمدون</span>
        <h2>نعمل مع أكبر المنصات العالمية</h2>
      </div>
      <div class="certs-row">
        <div class="cert" title="Google Partner">
          <svg class="cert__logo" viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          <span class="cert__name">Google Partner</span>
        </div>
        <div class="cert" title="Meta">
          <img src="/logos/meta.png" alt="Meta" class="cert__img" />
          <span class="cert__name">Meta</span>
        </div>
        <div class="cert" title="LinkedIn">
          <svg class="cert__logo" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          <span class="cert__name">LinkedIn</span>
        </div>
        <div class="cert" title="TikTok">
          <svg class="cert__logo" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          <span class="cert__name">TikTok</span>
        </div>
        <div class="cert" title="X (Twitter)">
          <svg class="cert__logo" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          <span class="cert__name">X</span>
        </div>
        <div class="cert" title="Semrush">
          <img src="/logos/semrush.jpg" alt="Semrush" class="cert__img" />
          <span class="cert__name">Semrush</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Media Spotlight -->
  <section class="section">
    <div class="container">
      <div class="spotlight">
        <div class="spotlight__text">
          <span class="tag">الخدمة الأبرز</span>
          <h2>إدارة وسائل التواصل الاجتماعي</h2>
          <p>نتولّى إدارة حساباتكم بالكامل — من التخطيط الاستراتيجي والتصميم إلى النشر والتفاعل مع الجمهور.</p>
          <ul class="check-list">
            <li>خطة محتوى شهرية متكاملة</li>
            <li>تصاميم احترافية مخصّصة لكل منصة</li>
            <li>إدارة التعليقات والرسائل الواردة</li>
            <li>تقارير أداء دورية وتحليلات مفصّلة</li>
          </ul>
          <a href="/contact" class="btn">اطلب هذه الخدمة</a>
        </div>
        <div class="spotlight__visual">
          <div class="spotlight__phone float">
            <div class="spotlight__screen">
              <div class="spotlight__post-header">
                <img src="/logo.png" alt="yallaadss" class="spotlight__avatar-img" />
                <div class="spotlight__header-info">
                  <span class="spotlight__username">yallaadss</span>
                  <span class="spotlight__handle">Marketing Agency</span>
                </div>
              </div>
              <div class="spotlight__post-body">
                <img src="/ig-post.jpg" alt="Yalla Ads post" class="spotlight__post-img" />
              </div>
              <div class="spotlight__engagement">
                <span>❤️ 1,247</span>
                <span>💬 89</span>
                <span>📤 156</span>
              </div>
              <p class="spotlight__caption"><strong>yallaadss</strong> بوستات استراتيجية، مفيدة، ومخطّطة...</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog -->
  {posts.length > 0 && (
    <section class="section section--light">
      <div class="container">
        <div class="sec-header">
          <span class="tag">المدونة</span>
          <h2>آخر المقالات</h2>
        </div>
        <div class="blog-grid">
          {posts.map(post => (
            <a href={`/blog/${post.id}`} class="blog-card">
              {post.data.image && <img src={post.data.image} alt={post.data.title} class="blog-card__img" loading="lazy" />}
              <div class="blog-card__body">
                <time>{post.data.date}</time>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </div>
            </a>
          ))}
        </div>
        <div class="sec-cta"><a href="/blog" class="btn btn--outline">كل المقالات</a></div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section cta-final">
    <div class="container">
      <div class="cta-box">
        <h2>هل أنتم مستعدّون للنمو؟</h2>
        <p>احصلوا على استشارة مجانية وخطة تسويق مخصّصة لمشروعكم.</p>
        <a href="/contact" class="btn">تواصلوا معنا الآن</a>
      </div>
    </div>
  </section>

</Base>

<style>
  /* Hero */
  .hero { padding: 5rem 0 3rem; }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 3rem;
    align-items: center;
  }
  .hero__orange { color: var(--orange); }
  .hero h1 { font-size: 3.2rem; margin-bottom: 1rem; }
  .hero__sub { font-size: 1.1rem; line-height: 1.8; margin-bottom: 1.5rem; }
  .hero__cta { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  /* Stats */
  .stats-section { padding: 2.5rem 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }
  .stat { text-align: center; padding: 1rem 0.5rem; }
  .stat__num { display: block; font-size: 2rem; font-weight: 900; color: var(--blue); font-feature-settings: 'tnum'; }
  :global([data-theme="dark"]) .stat__num { color: #fff; }
  .stat__label { font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.03em; }

  /* Section header */
  .sec-header { text-align: center; margin-bottom: 2.5rem; }
  .sec-header h2 { margin-bottom: 0.25rem; }
  .sec-header--light h2 { color: #fff; }
  .sec-cta { text-align: center; margin-top: 2rem; }

  /* Services */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }
  .svc-card {
    display: block;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: all 0.25s;
    background: var(--bg);
  }
  .svc-card:hover {
    border-color: var(--blue);
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .svc-card__icon { font-size: 1.75rem; display: block; margin-bottom: 0.75rem; }
  .svc-card h3 { margin-bottom: 0.35rem; color: var(--blue); }
  :global([data-theme="dark"]) .svc-card h3 { color: var(--text); }
  .svc-card p { font-size: 0.85rem; line-height: 1.6; }

  /* Steps */
  .steps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .step { text-align: center; padding: 1.5rem; }
  .step__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--blue);
    color: #fff;
    font-size: 1.25rem;
    font-weight: 900;
    margin-bottom: 1rem;
    font-family: system-ui, sans-serif;
  }
  .step h3 { margin-bottom: 0.5rem; }
  .step p { font-size: 0.9rem; }

  /* Certifications */
  .certs-row {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .cert {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .cert__logo {
    width: 40px;
    height: 40px;
    color: var(--text);
    opacity: 0.35;
    transition: opacity 0.25s;
  }
  .cert:hover .cert__logo { opacity: 0.7; }
  .cert__img {
    height: 40px;
    width: auto;
    object-fit: contain;
    filter: grayscale(1) opacity(0.35);
    transition: filter 0.25s;
  }
  .cert:hover .cert__img { filter: grayscale(0) opacity(0.8); }
  :global([data-theme="dark"]) .cert__img { filter: grayscale(1) brightness(3) opacity(0.35); }
  :global([data-theme="dark"]) .cert:hover .cert__img { filter: grayscale(0) brightness(1.2) opacity(0.8); }
  .cert__name { font-size: 0.75rem; font-weight: 600; color: var(--text-muted); text-align: center; }

  /* Spotlight */
  .spotlight {
    display: grid;
    grid-template-columns: 1fr 0.8fr;
    gap: 3rem;
    align-items: center;
  }
  .spotlight__text h2 { margin-bottom: 0.75rem; }
  .spotlight__text > p { margin-bottom: 1.25rem; line-height: 1.8; }
  .check-list { list-style: none; margin-bottom: 1.5rem; }
  .check-list li {
    padding: 0.4rem 0;
    padding-right: 1.5rem;
    position: relative;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
  .check-list li::before {
    content: '✓';
    position: absolute;
    right: 0;
    color: var(--blue);
    font-weight: 700;
  }
  :global([data-theme="dark"]) .check-list li::before { color: var(--orange); }
  .spotlight__phone {
    width: 240px;
    margin: 0 auto;
    background: #111;
    border-radius: 32px;
    padding: 10px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
  }
  .spotlight__screen {
    background: #fff;
    border-radius: 24px;
    overflow: hidden;
  }
  .spotlight__post-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.75rem;
  }
  .spotlight__avatar-img {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    object-fit: cover;
  }
  .spotlight__header-info { display: flex; flex-direction: column; }
  .spotlight__username { font-size: 0.72rem; font-weight: 800; color: #111; line-height: 1.2; }
  .spotlight__handle { font-size: 0.6rem; color: #888; }
  .spotlight__post-body { width: 100%; overflow: hidden; }
  .spotlight__post-img { width: 100%; height: auto; display: block; }
  .spotlight__engagement {
    display: flex;
    gap: 0.75rem;
    font-size: 0.65rem;
    color: #555;
    padding: 0.5rem 0.75rem 0.25rem;
  }
  .spotlight__caption {
    font-size: 0.6rem;
    color: #555;
    padding: 0 0.75rem 0.6rem;
    line-height: 1.4;
    direction: rtl;
  }
  .spotlight__caption strong { color: #111; }

  /* Blog */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
    gap: 1rem;
  }
  .blog-card {
    display: block;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: all 0.25s;
    background: var(--bg);
  }
  .blog-card:hover { border-color: var(--blue); transform: translateY(-4px); box-shadow: var(--shadow-md); }
  .blog-card__img { width: 100%; height: 180px; object-fit: cover; }
  .blog-card__body { padding: 1.25rem; }
  .blog-card time { font-size: 0.85rem; color: #2A4494; font-weight: 600; }
  :global([data-theme="dark"]) .blog-card time { color: #7ba0ff; }
  .blog-card h3 { font-size: 1rem; margin: 0.4rem 0; line-height: 1.5; }
  .blog-card p {
    font-size: 0.85rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* CTA */
  .cta-box {
    text-align: center;
    padding: 3.5rem 2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg);
  }
  .cta-box h2 { margin-bottom: 0.5rem; }
  .cta-box p { max-width: 450px; margin: 0 auto 1.5rem; }

  /* Responsive */
  @media (max-width: 768px) {
    .hero__inner { grid-template-columns: 1fr; gap: 2rem; }
    .hero h1 { font-size: 2.4rem; }
    .hero__tool { order: -1; }
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .steps-grid { grid-template-columns: 1fr; gap: 1rem; }
    .step { padding: 1rem; }
    .spotlight { grid-template-columns: 1fr; gap: 2rem; }
    .spotlight__phone { width: 180px; }
    .blog-grid { grid-template-columns: 1fr; }
    .certs-row { gap: 1.5rem; }
    .cert__logo { width: 32px; height: 32px; }
  }

  @media (max-width: 480px) {
    .hero { padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2rem; }
    .hero__cta { flex-direction: column; }
    .hero__cta .btn { width: 100%; text-align: center; }
    .stat__num { font-size: 1.5rem; }
    .services-grid { grid-template-columns: 1fr; }
    .cta-box { padding: 2.5rem 1.5rem; }
  }
</style>
