---
import Base from '../layouts/Base.astro';

const values = [
  { icon: '🎯', title: 'نتائج حقيقية', desc: 'ما نبيع وعود — نبيع نتائج. كل قرار مبني على بيانات وأرقام.' },
  { icon: '🤝', title: 'شراكة حقيقية', desc: 'نتعامل مع مشروعك مثل ما هو مشروعنا. نجاحك هو نجاحنا.' },
  { icon: '💡', title: 'إبداع بلا حدود', desc: 'نفكر خارج الصندوق ونجرب أفكار جديدة عشان نميزك عن المنافسين.' },
  { icon: '📊', title: 'شفافية كاملة', desc: 'تقارير واضحة وصريحة. تعرف وين تروح كل ريال من ميزانيتك.' },
  { icon: '⚡', title: 'سرعة التنفيذ', desc: 'ما نأخر. نبدأ الشغل بسرعة ونلتزم بالمواعيد.' },
  { icon: '🌍', title: 'خبرة إقليمية', desc: 'نفهم السوق العربي ونعرف كيف نوصل الرسالة الصحيحة للجمهور الصحيح.' },
];

const stats = [
  { number: '+150', label: 'عميل' },
  { number: '+500', label: 'حملة' },
  { number: '+5', label: 'سنوات خبرة' },
  { number: '98%', label: 'رضا العملاء' },
];
---

<Base
  title="من نحن — يلا ادز | وكالة تسويق رقمي"
  description="يلا ادز وكالة تسويق رقمي متخصصة في خدمة المشاريع العربية. نساعدك توصل للزبون الصحيح."
>

  <section class="page-header">
    <div class="container">
      <p class="tag">من نحن</p>
      <h1>فريق يحب التسويق ويفهم السوق العربي</h1>
      <p class="page-header__sub">نحن فريق من خبراء التسويق الرقمي شغوفين بمساعدة المشاريع العربية تنمو وتنجح في العالم الرقمي.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="about-grid">
        <div class="about-text">
          <h2>قصتنا</h2>
          <p>بدأنا يلا ادز بهدف واحد بسيط: نساعد أصحاب المشاريع العرب يوصلون لعملائهم بأسهل وأذكى الطرق.</p>
          <p>شفنا كثير من المشاريع الممتازة تضيع بسبب تسويق ضعيف أو وكالات ما تفهم السوق العربي. قررنا نكون الحل — وكالة تتكلم لغتك، تفهم جمهورك، وتشتغل معك كشريك حقيقي.</p>
          <p>اليوم، نخدم عملاء في السعودية، الإمارات، الكويت، الأردن وأكثر. ومازلنا بنفس الشغف والالتزام اللي بدأنا فيه.</p>
        </div>
        <div class="about-stats glass">
          {stats.map(s => (
            <div class="about-stat">
              <span class="about-stat__number">{s.number}</span>
              <span class="about-stat__label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="sec-header sec-header--light">
        <p class="tag">قيمنا</p>
        <h2>ليش تختارنا؟</h2>
      </div>
      <div class="values-grid">
        {values.map(v => (
          <div class="value-card">
            <span class="value-card__icon">{v.icon}</span>
            <h3>{v.title}</h3>
            <p>{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-box glass">
        <h2>تبي تعرف أكثر؟</h2>
        <p>تواصل معنا ونحكيلك كيف نقدر نساعد مشروعك ينمو.</p>
        <a href="/contact" class="btn">تواصل معنا</a>
      </div>
    </div>
  </section>

</Base>

<style>
  .page-header {
    padding: 5rem 0 2rem;
    text-align: center;
  }

  .page-header h1 { margin-bottom: 1rem; }
  .page-header__sub { font-size: 1.1rem; max-width: 600px; margin: 0 auto; }

  .about-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 4rem;
    align-items: center;
  }

  .about-text h2 { margin-bottom: 1.5rem; }

  .about-text p {
    font-size: 1.05rem;
    line-height: 1.9;
    margin-bottom: 1rem;
  }

  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    padding: 2.5rem;
    border-radius: var(--radius-lg);
  }

  .about-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.25rem;
  }

  .about-stat__number {
    font-size: 2.2rem;
    font-weight: 900;
    color: #1B2E6E;
  }

  .about-stat__label {
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .sec-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .sec-header--light h2 { color: #fff; }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .value-card {
    padding: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius);
    transition: all 0.3s;
  }

  .value-card:hover {
    border-color: rgba(91, 140, 255, 0.4);
    background: rgba(255, 255, 255, 0.03);
  }

  .value-card__icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 1rem;
  }

  .value-card h3 { color: #fff; margin-bottom: 0.5rem; }
  .value-card p { color: rgba(255, 255, 255, 0.6); font-size: 0.9rem; }

  .cta-box {
    text-align: center;
    padding: 4rem 2rem;
    border-radius: var(--radius-lg);
  }

  .cta-box h2 { margin-bottom: 1rem; }
  .cta-box > p { max-width: 500px; margin: 0 auto 2rem; }

  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; gap: 2rem; }
    .about-stats { padding: 2rem; }
    .values-grid { grid-template-columns: repeat(auto-fill, minmax(min(260px, 100%), 1fr)); }
  }

  @media (max-width: 480px) {
    .page-header { padding: 3.5rem 0 1.5rem; }
    .page-header h1 { font-size: 1.5rem; }
    .about-text p { font-size: 0.95rem; }
    .about-stat__number { font-size: 1.8rem; }
    .values-grid { grid-template-columns: 1fr; }
    .value-card { padding: 1.5rem; }
    .cta-box { padding: 2rem 1.5rem; }
  }
</style>
