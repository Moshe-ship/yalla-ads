---
const services = [
  { href: '/services#google-ads', label: 'إعلانات قوقل' },
  { href: '/services#social-media', label: 'إدارة السوشال ميديا' },
  { href: '/services#seo', label: 'تحسين محركات البحث' },
  { href: '/services#content', label: 'صناعة المحتوى' },
  { href: '/services#leads', label: 'جذب العملاء' },
];

const company = [
  { href: '/about', label: 'من نحن' },
  { href: '/blog', label: 'المدونة' },
  { href: '/contact', label: 'تواصل معنا' },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <img src="/logo.png" alt="يلا ادز" class="footer__logo-img" width="140" height="56" />
        <p class="footer__tagline">منوصلك للزبون الصحيح</p>
        <div class="footer__social">
          <a href="https://instagram.com/yallaadss" target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
          </a>
        </div>
      </div>

      <div class="footer__col">
        <h4>خدماتنا</h4>
        {services.map(s => <a href={s.href}>{s.label}</a>)}
      </div>

      <div class="footer__col">
        <h4>الشركة</h4>
        {company.map(c => <a href={c.href}>{c.label}</a>)}
      </div>

      <div class="footer__col">
        <h4>تواصل معنا</h4>
        <a href="mailto:info@yalla-ads.com">info@yalla-ads.com</a>
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; {new Date().getFullYear()} يلا ادز — Yalla Ads. جميع الحقوق محفوظة.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--navy-deep);
    color: rgba(255, 255, 255, 0.6);
    padding: 4rem 0 2rem;
    margin-top: 2rem;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 3rem;
  }

  .footer__logo-img {
    height: 48px;
    width: auto;
    margin-bottom: 1rem;
    filter: brightness(1.2) saturate(1.3);
  }

  .footer__tagline {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .footer__social {
    display: flex;
    gap: 0.75rem;
  }

  .footer__social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-sm);
    color: rgba(255, 255, 255, 0.5);
    transition: all 0.3s;
  }

  .footer__social a:hover {
    color: var(--orange);
    border-color: var(--orange);
  }

  .footer__col h4 {
    color: #fff;
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer__col a {
    display: block;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9rem;
    padding: 0.3rem 0;
    transition: color 0.3s;
  }

  .footer__col a:hover { color: var(--orange); }

  .footer__bottom {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    text-align: center;
  }

  .footer__bottom p {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.35);
  }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .footer__brand { grid-column: 1 / -1; }
  }

  @media (max-width: 480px) {
    .footer__grid { grid-template-columns: 1fr; }
  }
</style>
